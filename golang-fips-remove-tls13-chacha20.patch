diff --git a/src/crypto/tls/cipher_suites.go b/src/crypto/tls/cipher_suites.go
index 1111111111..2222222222 100644
--- a/src/crypto/tls/cipher_suites.go
+++ b/src/crypto/tls/cipher_suites.go
@@ -500,9 +500,20 @@ func aeadAESGCMTLS13(key, nonceMask []byte) aead {
 	return (*aeadAESGCMTLS13)(aead)
 }

-// cipherSuitesTLS13 contains all TLS 1.3 cipher suites that are implemented
-// in the standard library.
+// cipherSuitesTLS13 contains all TLS 1.3 cipher suites.
+// FIPS 140-3 Compliance Modification:
+// - Removed TLS_CHACHA20_POLY1305_SHA256 (non-FIPS algorithm)
+// - ChaCha20-Poly1305 uses golang.org/x/crypto which bypasses FIPS validation
+// - Only AES-GCM cipher suites remain (routed through golang-fips/go → OpenSSL → wolfProvider)
+//
+// Original Go standard library included 3 TLS 1.3 cipher suites:
+//   1. TLS_AES_128_GCM_SHA256        ← FIPS-approved (kept)
+//   2. TLS_AES_256_GCM_SHA384        ← FIPS-approved (kept)
+//   3. TLS_CHACHA20_POLY1305_SHA256  ← NON-FIPS (removed for FIPS compliance)
+//
+// This patch ensures TLS 1.3 connections ONLY use FIPS-validated cryptography.
 var cipherSuitesTLS13 = []*cipherSuiteTLS13{
-	{TLS_AES_128_GCM_SHA256, 16, aeadAESGCMTLS13},
-	{TLS_AES_256_GCM_SHA384, 32, aeadAESGCMTLS13},
-	{TLS_CHACHA20_POLY1305_SHA256, 32, aeadChaCha20Poly1305},
+	{TLS_AES_128_GCM_SHA256, 16, aeadAESGCMTLS13},  // FIPS-approved: AES-128-GCM
+	{TLS_AES_256_GCM_SHA384, 32, aeadAESGCMTLS13},  // FIPS-approved: AES-256-GCM
+	// REMOVED for FIPS 140-3 compliance:
+	// {TLS_CHACHA20_POLY1305_SHA256, 32, aeadChaCha20Poly1305},  // NON-FIPS algorithm
 }
